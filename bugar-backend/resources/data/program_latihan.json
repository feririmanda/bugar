{
  "_meta": {
    "evidence_basis": "Volume 12-20 set/minggu per kelompok otot (Baz-Valle et al. 2022, J Hum Kinet), frekuensi 2-4x/minggu sama efektif bila volume disetarakan (Schoenfeld et al. 2019, Sports Med)",
    "disclaimer": "Program berdasarkan prinsip umum exercise science. Hasil individu bervariasi tergantung genetik, nutrisi, recovery, dan konsistensi. Konsultasikan ke dokter sebelum mulai program jika memiliki kondisi medis tertentu.",
    "progressive_overload_rule": {
      "kondisi_naik_beban": "User mencapai target_reps maksimum di SEMUA set pada 2 sesi berturut-turut untuk exercise yang sama",
      "kenaikan_beban": "+2.5kg untuk dumbbell/barbel upper body, +5kg untuk lower body (squat/deadlift), atau +1-2 reps jika bodyweight",
      "kondisi_naik_reps_bodyweight": "User mencapai target_reps maksimum di semua set pada 2 sesi berturut-turut, dan tidak ada beban tambahan (pure bodyweight) → naikkan reps range +2-3, atau ganti ke variasi lebih sulit (contoh: Push Up biasa → Diamond Push Up)",
      "kondisi_turun": "User gagal mencapai target_reps minimum di 2+ set pada 2 sesi berturut-turut → turunkan beban 10% atau kembali ke reps range sebelumnya",
      "sumber": "Prinsip progressive overload standar (double progression model): naikkan reps dalam range dulu, baru naikkan beban saat reps maksimum tercapai konsisten"
    }
  },
